# Airtable (server-only; never expose to client bundles)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_PHYSICIANS_TABLE=Physicians
AIRTABLE_AUDIT_TABLE=AuditLog
AIRTABLE_PRESCRIPTIONS_TABLE=Prescriptions
AIRTABLE_PDF_FIELD_ID=
AIRTABLE_PHYSICIANS_SIGNATURE_FIELD_ID=

# Firebase client auth config (safe to expose in browser; values from Firebase console)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: comma-separated emails that should be treated as Admin in UI
NEXT_PUBLIC_ADMIN_EMAILS=
